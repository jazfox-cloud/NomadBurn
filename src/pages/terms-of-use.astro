---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailLink from "../components/EmailLink.astro";

const title = "Terms of Use | NomadBurn";
const description =
  "NomadBurn terms of use for the digital nomad burn rate calculator, city estimates, optional AI diagnosis, and educational content.";
---

<BaseLayout title={title} description={description} canonicalPath="/terms-of-use/">
  <section class="content-hero">
    <p class="eyebrow">Terms</p>
    <h1>Terms of Use</h1>
    <p class="subtitle">
      Last updated July 8, 2026. By using NomadBurn, you agree to use it as educational planning
      software, not as professional advice.
    </p>
  </section>

  <section class="content-panel">
    <h2>Educational use only</h2>
    <p>
      NomadBurn provides calculators, city estimates, methodology notes, and optional AI-generated
      planning summaries for general educational purposes. NomadBurn does not provide financial,
      tax, legal, investment, healthcare, insurance, or immigration advice.
    </p>
  </section>

  <section class="content-panel">
    <h2>Your responsibility</h2>
    <p>
      You are responsible for verifying housing prices, taxes, visas, insurance, legal obligations,
      income reliability, and personal financial decisions before moving or spending money. Do not
      rely on NomadBurn as the only source for any decision with legal, financial, or personal risk.
    </p>
  </section>

  <section class="content-panel">
    <h2>Cost estimates and AI output</h2>
    <p>
      City costs are rough planning assumptions, not live quotes or guarantees. Optional AI diagnosis
      may be incomplete, outdated, or wrong. Use it to generate questions and checks, then verify the
      important parts yourself.
    </p>
  </section>

  <section class="content-panel">
    <h2>Acceptable use</h2>
    <ul class="plain-list">
      <li>Do not attack, overload, scrape aggressively, or interfere with the site.</li>
      <li>Do not submit sensitive personal, financial, medical, legal, or immigration data.</li>
      <li>Do not present NomadBurn output as professional advice or a guaranteed cost forecast.</li>
      <li>Do not use the site in a way that violates applicable law.</li>
    </ul>
  </section>

  <section class="content-panel">
    <h2>Changes</h2>
    <p>
      NomadBurn may update the calculator, assumptions, pages, features, and these terms over time.
      Continued use of the site after changes means you accept the updated terms.
    </p>
  </section>

  <section class="content-panel">
    <h2>Contact</h2>
    <p>
      Questions about these terms can be sent to
      <EmailLink />.
    </p>
  </section>
</BaseLayout>
