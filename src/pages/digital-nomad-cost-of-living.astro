---
import BaseLayout from "../layouts/BaseLayout.astro";
import { cities, cityLabel, destinationNames } from "../data/cities";
import { cityPath, money, monthlyCostFor } from "../lib/seo";

const title = "Digital Nomad Cost of Living Comparison | NomadBurn";
const description =
  "Compare rough 2026 rent and living-cost estimates for digital nomad cities, then see how each destination changes monthly burn and savings runway.";
---

<BaseLayout title={title} description={description} canonicalPath="/digital-nomad-cost-of-living/">
  <section class="content-hero">
    <p class="eyebrow">City comparison</p>
    <h1>Digital nomad cost of living comparison</h1>
    <p class="subtitle">
      Compare rough monthly planning assumptions for popular remote-work cities, including expanded
      Eastern Europe and Central Europe coverage, then use the burn rate calculator to replace the
      defaults with your own income and savings.
    </p>
  </section>

  <section class="content-panel">
    <h2>2026 Planning Estimates, Not Live Quotes</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>City</th>
            <th>Base living</th>
            <th>Coliving</th>
            <th>Airbnb solo</th>
            <th>Hostel</th>
            <th>Sample monthly setup</th>
          </tr>
        </thead>
        <tbody>
          {
            destinationNames.map((city) => (
              <tr>
                <td><a href={cityPath(city)}>{cityLabel(city)}</a></td>
                <td>{money(cities[city].baseLivingCost)}</td>
                <td>{money(cities[city].colivingRent)}</td>
                <td>{money(cities[city].airbnbRent)}</td>
                <td>{money(cities[city].hostelRent)}</td>
                <td>{money(monthlyCostFor(city))}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="source-note">
      Last reviewed: July 2026. Sample setup assumes coliving, three coworking or cafe work
      sessions per week, $100 fixed costs, and a $150 flight or visa buffer. Rent, coworking,
      SIM/data, and seasonal travel can move quickly. See the
      <a href="/methodology/">NomadBurn cost methodology</a> before treating any estimate as a real
      quote.
    </p>
  </section>
</BaseLayout>
